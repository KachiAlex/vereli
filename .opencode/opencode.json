{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "edit": {
      "**/vite.config.js": "deny",
      "**/vite.config.ts": "deny",
      "**/vercel.ts": "deny",
      "**/vercel.json": "deny",
      "**/middleware.ts": "deny",
      "**/package.json": "deny",
      "**/pnpm-workspace.yaml": "deny",
      "**/pnpm-lock.yaml": "deny",
      "**/redirects.csv": "deny",
      "**/drizzle.config.ts": "deny",
      "api/**": "deny",
      "**/.opencode/**": "deny",
      "**/.claude/**": "deny",
      "**/.cursor/**": "deny",
      "**/workpad.json": "deny",
      "plans/**": "deny",
      "generators/**": "deny",
      "**/server.ts": "deny",
      "**/server.js": "deny",
      "**/server.mjs": "deny",
      "**/proxy.ts": "deny",
      "**/proxy.js": "deny",
      "**/proxy.mjs": "deny",
      "**/ai-proxy/**": "deny",
      "**/relay/**": "deny",
      "**/ecosystem.config.*": "deny",
      "**/Caddyfile": "deny",
      "**/Procfile": "deny",
      "*": "allow"
    },
    "bash": "allow",
    "write": {
      "**/vite.config.js": "deny",
      "**/vite.config.ts": "deny",
      "**/vercel.ts": "deny",
      "**/vercel.json": "deny",
      "**/middleware.ts": "deny",
      "**/package.json": "deny",
      "**/pnpm-workspace.yaml": "deny",
      "**/pnpm-lock.yaml": "deny",
      "**/redirects.csv": "deny",
      "**/drizzle.config.ts": "deny",
      "api/**": "deny",
      "**/.opencode/**": "deny",
      "**/.claude/**": "deny",
      "**/.cursor/**": "deny",
      "**/workpad.json": "deny",
      "plans/**": "deny",
      "generators/**": "deny",
      "**/server.ts": "deny",
      "**/server.js": "deny",
      "**/server.mjs": "deny",
      "**/proxy.ts": "deny",
      "**/proxy.js": "deny",
      "**/proxy.mjs": "deny",
      "**/ai-proxy/**": "deny",
      "**/relay/**": "deny",
      "**/ecosystem.config.*": "deny",
      "**/Caddyfile": "deny",
      "**/Procfile": "deny",
      "*": "allow"
    },
    "webfetch": "allow"
  },
  "compaction": {
    "auto": true,
    "prune": true
  },
  "default_agent": "coding",
  "model": "anthropic/claude-sonnet-4-6",
  "provider": {
    "anthropic": {
      "options": {
        "baseURL": "{env:OPENCODE_PROXY_URL}",
        "apiKey": "{env:OPENROUTER_API_KEY}"
      },
      "models": {
        "claude-sonnet-4-6": {
          "limit": {
            "context": 300000,
            "output": 64000
          }
        },
        "claude-opus-4-6": {
          "limit": {
            "context": 300000,
            "output": 64000
          }
        }
      }
    },
    "openai": {
      "options": {
        "baseURL": "{env:OPENCODE_PROXY_URL}",
        "apiKey": "{env:OPENROUTER_API_KEY}"
      },
      "models": {
        "gpt-5": {
          "limit": {
            "context": 76800,
            "output": 128000
          }
        }
      }
    },
    "google": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Google",
      "options": {
        "baseURL": "{env:OPENCODE_PROXY_URL}",
        "apiKey": "{env:OPENROUTER_API_KEY}"
      },
      "models": {
        "gemini-2.5-pro": {
          "limit": {
            "context": 600000,
            "output": 64000
          }
        },
        "gemini-3.1-pro-preview": {
          "limit": {
            "context": 600000,
            "output": 64000
          }
        },
        "gemini-3-flash-preview": {
          "limit": {
            "context": 300000,
            "output": 64000
          }
        }
      }
    }
  }
}